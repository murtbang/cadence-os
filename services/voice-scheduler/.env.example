# Discord bot token (Developer Portal → your app → Bot → Reset Token)
DISCORD_BOT_TOKEN=

# OpenAI key — used for Whisper transcription
OPENAI_API_KEY=

# ID of the channel the bot watches (right-click channel → Copy ID, Developer Mode on)
CHANNEL_ID=

# Cadence endpoint that parses the transcript and writes to Google Calendar
SCHEDULE_URL=https://YOUR-CADENCE-DEPLOYMENT/api/schedule

# Shared secret — must exactly match SCHEDULE_SECRET set on the Cadence/Vercel side
SCHEDULE_SECRET=
