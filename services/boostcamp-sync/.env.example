# ── Boostcamp login (the only place these credentials live) ──
BOOSTCAMP_EMAIL=your@email.com
BOOSTCAMP_PASSWORD=yourpassword

# ── Supabase (service_role key, since the sync writes rows) ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# ── Shared secret guarding POST /sync — must match the value set in the
#    cadence app on Vercel (BOOSTCAMP_SYNC_SECRET). Generate any long random string. ──
BOOSTCAMP_SYNC_SECRET=change-me-to-a-long-random-string

# ── Optional: Discord webhook for "workout logged" and crash alerts ──
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Optional: timezone offset from UTC in minutes for week math + Boostcamp API.
#    -420 = UTC-7 (US Pacific, summer). -480 = UTC-8 (winter). 0 = UTC. Default -420. ──
TZ_OFFSET_MINUTES=-420
