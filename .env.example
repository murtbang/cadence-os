# ============================================================================
# Cadence — environment variables
# ============================================================================
# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# In production, set the same variables in your Vercel project settings.
# See README.md → "Setup" for how to obtain each value.
#
# Legend:  [required]  the app won't work without it
#          [optional]  a feature is disabled/skipped if unset (never crashes)
# ============================================================================

# ── Supabase (database) ─────────────────────────────────────────── [required]
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only "service_role" key. All server routes use it and it BYPASSES RLS,
# so you can enable RLS (see db/schema.sql) and lock out the public anon role.
# NEVER prefix this with NEXT_PUBLIC_ and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── App auth ────────────────────────────────────────────────────── [required]
# The PIN you type to unlock the dashboard. Pick something real (not 1234).
DASHBOARD_PIN=
# Shared machine secret. Used for: Vercel Cron auth, the login-cookie HMAC key,
# and Discord dismiss-link signing. Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Rotating this logs every device out.
CRON_SECRET=
# Your deployment's public URL (used to build Discord reminder links).
# e.g. https://your-cadence.vercel.app  — no trailing slash.
NEXT_PUBLIC_APP_URL=

# ── Location (weather) ──────────────────────────────────────────── [optional]
# Your coordinates for the weather card (US National Weather Service — US only,
# no API key). Find yours at https://www.latlong.net. Defaults to Rancho
# Cucamonga, CA if unset. Also update the display label — see README → Customize.
WEATHER_LAT=
WEATHER_LON=

# ── Google Calendar ─────────────────────────────────────── [optional, recommended]
# READ path (dashboard/calendar view + reminders): the "secret address in iCal
# format" from Google Calendar → Settings → your calendar → Integrate calendar.
GOOGLE_CALENDAR_ICAL_URL=
# WRITE path (creating/editing events via Discord /calendar and voice). OAuth:
GOOGLE_CALENDAR_ID=            # usually your email, or a specific calendar id
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Discord ─────────────────────────────────────────────── [optional, recommended]
# Discord Developer Portal → your application.
DISCORD_PUBLIC_KEY=            # General Information → Public Key
DISCORD_APP_ID=                # General Information → Application ID
DISCORD_BOT_TOKEN=             # Bot → Reset/Copy Token
DISCORD_ALERTS_WEBHOOK_URL=    # a channel webhook for reminders/check-ins
DISCORD_LOGS_WEBHOOK_URL=      # (optional) a second webhook for quiet activity logs
# Optional: dedicated secret for the /api/discord/register endpoint.
# If unset, that endpoint falls back to CRON_SECRET.
REGISTER_SECRET=

# ── Voice-to-action (optional) ──────────────────────────────────── [optional]
# Powers /api/schedule — turns a spoken/typed sentence into an event/todo/etc.
ANTHROPIC_API_KEY=             # console.anthropic.com
SCHEDULE_SECRET=               # shared secret the caller sends as x-schedule-secret

# ── Govee smart lights (optional) ───────────────────────────────── [optional]
# developer.govee.com → apply for an API key. Powers the dashboard Lights card.
GOVEE_API_KEY=

# ── Boostcamp training sync (optional) ──────────────────────────── [optional]
# Only if you run the companion Boostcamp sync service. See its own repo/DEPLOY.md.
BOOSTCAMP_SYNC_URL=            # the sync service's public URL
BOOSTCAMP_SYNC_SECRET=        # must match the value set on the sync service
